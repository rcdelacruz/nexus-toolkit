{
  "name": "monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "db:generate": "turbo run db:generate --filter=./packages/db",
    "db:migrate": "turbo run db:migrate --filter=./packages/db",
    "db:studio": "turbo run db:studio --filter=./packages/db",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "turbo": "^2.8.10",
    "typescript": "^5",
    "@tailwindcss/postcss": "^4.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
