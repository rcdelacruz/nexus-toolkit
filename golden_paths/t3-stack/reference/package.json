{
  "name": "t3-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "format": "prettier --write .",
    "db:generate": "prisma generate --config prisma/config.ts",
    "db:migrate": "prisma migrate dev --config prisma/config.ts",
    "db:push": "prisma db push --config prisma/config.ts",
    "db:studio": "prisma studio --config prisma/config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@radix-ui/react-slot": "^1.1.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "pg": "^8.18.0",
    "@tanstack/react-query": "^5.67.0",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "next": "^16.1.0",
    "next-auth": "^4.24.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.0.1",
    "isomorphic-dompurify": "^2.25.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/node": "^22",
    "@types/pg": "^8.11.14",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.0",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "prisma": "^7.4.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "msw": "^2.7.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@vitest/coverage-v8": "^3.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
