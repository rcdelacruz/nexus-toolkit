{
  "name": "nextjs-fullstack",
  "version": "2.0.0",
  "description": "Next.js 16 App Router + tRPC v11 + Prisma v7 + NextAuth v5 + Zustand v5 + Tailwind v4 + shadcn/ui",
  "triggers": {
    "hasAuth": [
      "login",
      "register",
      "signin",
      "signup",
      "auth",
      "forgot-password"
    ],
    "hasDashboard": [
      "dashboard",
      "admin",
      "panel",
      "analytics",
      "overview"
    ],
    "hasDataLists": [
      "table",
      "list",
      "grid",
      "feed",
      "users",
      "orders"
    ],
    "hasSidebar": [
      "sidebar",
      "drawer",
      "navigation",
      "nav-rail"
    ]
  },
  "routing": {
    "strategy": "app-router",
    "pageKeywords": [
      "page",
      "screen",
      "view",
      "route"
    ],
    "asyncParams": true,
    "groupKeywords": {
      "(auth)": [
        "login",
        "register",
        "signup",
        "signin"
      ],
      "(dashboard)": [
        "dashboard",
        "admin",
        "settings",
        "profile"
      ]
    }
  },
  "tailwind": {
    "version": 4,
    "configFile": null,
    "cssFile": "app/globals.css",
    "tokenDirective": "@theme inline",
    "animatePackage": "tw-animate-css"
  },
  "tokenTargets": [
    "app/globals.css"
  ],
  "requiredFiles": [
    "app/layout.tsx",
    "app/globals.css",
    "lib/utils.ts",
    "lib/db.ts",
    "instrumentation.ts",
    "lib/auth.ts",
    "server/trpc.ts",
    "server/api/root.ts",
    "trpc/react.tsx",
    "store/useAppStore.ts",
    "prisma/schema.prisma",
    "prisma/config.ts",
    "next.config.ts",
    "tsconfig.json",
    "package.json",
    ".env.example",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "eslint.config.mjs",
    ".prettierrc",
    "commitlint.config.mjs",
    "postcss.config.mjs",
    ".husky/pre-commit",
    ".nvmrc",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    ".github/dependabot.yml",
    ".github/PULL_REQUEST_TEMPLATE.md",
    ".github/ISSUE_TEMPLATE/bug_report.md",
    ".github/ISSUE_TEMPLATE/feature_request.md",
    ".github/workflows/ci.yml",
    "app/api/health/route.ts",
    "app/error.tsx",
    "app/not-found.tsx",
    "app/global-error.tsx",
    "lib/env.ts",
    "lib/logger.ts",
    "prisma/seed.ts",
    "tests/setup.ts",
    "tests/msw/handlers.ts",
    "tests/msw/server.ts",
    "vitest.config.ts",
    "lib/csrf.ts",
    "lib/sanitize.ts"
  ],
  "optionalFiles": {
    "hasAuth": [
      "app/(auth)/login/page.tsx",
      "app/(auth)/register/page.tsx",
      "app/api/auth/[...nextauth]/route.ts",
      "proxy.ts"
    ],
    "hasDashboard": [
      "app/(dashboard)/layout.tsx",
      "app/(dashboard)/dashboard/page.tsx"
    ],
    "hasSidebar": [
      "components/layout/Sidebar.tsx"
    ],
    "hasDataLists": [
      "types/index.ts"
    ]
  },
  "classification": {
    "categories": {
      "ui": {
        "outputPath": "components/ui/{ComponentName}.tsx",
        "signals": [
          "Button",
          "Input",
          "Select",
          "Checkbox",
          "Radio",
          "Toggle",
          "Badge",
          "Avatar",
          "Tooltip",
          "Popover",
          "Dialog",
          "Sheet",
          "Dropdown",
          "Menu",
          "Tabs",
          "Accordion",
          "Separator",
          "Skeleton",
          "Spinner",
          "Icon",
          "Label",
          "Textarea",
          "Switch"
        ]
      },
      "layout": {
        "outputPath": "components/layout/{ComponentName}.tsx",
        "signals": [
          "Header",
          "Footer",
          "Sidebar",
          "Navbar",
          "Nav",
          "Navigation",
          "TopBar",
          "BottomBar",
          "Shell",
          "Container",
          "Wrapper"
        ]
      },
      "feature": {
        "outputPath": "components/features/{domain}/{ComponentName}.tsx",
        "signals": [
          "Dashboard",
          "Profile",
          "Settings",
          "Auth",
          "Login",
          "Signup",
          "Form",
          "Table",
          "List",
          "Grid",
          "Chart",
          "Stats",
          "Analytics"
        ]
      },
      "page": {
        "outputPath": "app/{route}/page.tsx",
        "signals": [
          "Page",
          "View",
          "Screen",
          "Route"
        ]
      }
    }
  }
}
